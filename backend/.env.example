# GitHub OAuth — github.com → Settings → Developer settings → OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# Database — run: docker compose up -d
DATABASE_URL=postgresql+asyncpg://gitreview:gitreview@localhost:5432/gitreview

# JWT — generate key: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# App
FRONTEND_URL=http://localhost:3000
COOKIE_SECURE=False  # Set True in production (requires HTTPS)

# LLM (Ollama Cloud API)
OLLAMA_API_KEY=your_ollama_api_key
LLM_BASE_URL=https://ollama.com
LLM_MODEL=gpt-oss:120b
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
